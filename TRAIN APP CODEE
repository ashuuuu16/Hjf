        // Class display info.
        const CLASS_INFO = {
            general: { name: 'General (GEN)', desc: 'Basic seating • Lowest fare', emoji: '🪑', multiplier: 1 },
            sleeper: { name: 'Sleeper (SL)', desc: 'Comfortable berths • Budget-friendly', emoji: '🛏️', multiplier: 1.9 },
