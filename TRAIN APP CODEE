/* Page Setup */
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RailWay - Indian Railway Booking System</title>
    <style>
        :root {
            --primary: #1a3a5c;
            --primary-light: #1e5080;
            --accent: #e85d2c;
            --accent-hover: #d14f20;
            --gold: #f0a500;
            --bg: #f4f6f9;
            --white: #ffffff;
            --card: #ffffff;
            --text: #2c3e50;
            --text-light: #5a6c7d;
            --border: #dde4ed;
            --success: #27ae60;
            --danger: #d51601;
            --shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.12);
            --radius: 14px;
            --radius-sm: 8px;
            --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Poppins', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #e8eef5 0%, #dce4f0 30%, #f0f3f8 60%, #e4eaf3 100%);
            min-height: 100vh;
            color: var(--text);
            line-height: 1.6;
            position: relative;
            overflow-x: hidden;
        }

        /* Subtle background pattern */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background:
                radial-gradient(ellipse at 15% 20%, rgba(26, 58, 92, 0.03) 0%, transparent 60%),
                radial-gradient(ellipse at 85% 75%, rgba(232, 93, 44, 0.03) 0%, transparent 60%),
                radial-gradient(ellipse at 50% 50%, rgba(240, 165, 0, 0.02) 0%, transparent 50%);
        }

        /* HEADER */
        .navbar {
            background: var(--primary);
            color: #fff;
            padding: 0 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 64px;
            box-shadow: 0 3px 16px rgba(0, 0, 0, 0.18);
            position: sticky;
            top: 0;
            z-index: 1000;
            flex-wrap: wrap;
        }
        .navbar .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.45rem;
            font-weight: 700;
            letter-spacing: -0.3px;
            white-space: nowrap;
        }
        .navbar .logo .icon {
            font-size: 1.8rem;
        }
        .navbar .logo span {
            color: var(--gold);
        }
        .nav-links {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
        }
        .nav-links button {
            padding: 9px 18px;
            border: 2px solid rgba(255, 255, 255, 0.35);
            background: transparent;
            color: #fff;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: var(--transition);
            white-space: nowrap;
            letter-spacing: 0.2px;
        }
        .nav-links button:hover {
            background: rgba(255, 255, 255, 0.13);
            border-color: #fff;
            transform: translateY(-1px);
        }
        .nav-links button.btn-accent {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
            font-weight: 700;
            box-shadow: 0 3px 12px rgba(232, 93, 44, 0.35);
        }
        .nav-links button.btn-accent:hover {
            background: var(--accent-hover);
            border-color: var(--accent-hover);
            box-shadow: 0 6px 20px rgba(232, 93, 44, 0.45);
            transform: translateY(-2px);
        }
        .user-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.12);
            padding: 7px 14px;
            border-radius: 25px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: default;
        }
        .user-badge .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--primary);
            font-size: 0.85rem;
        }

        /*  MAIN CONTAINER*/
        .container {
            max-width: 1050px;
            margin: 0 auto;
            padding: 28px 20px 40px;
            position: relative;
            z-index: 1;
        }

        /*  PAGE SECTIONS  */
        .page {
            display: none;
            animation: fadeSlideIn 0.45s ease forwards;
        }
        .page.active {
            display: block;
        }
        @keyframes fadeSlideIn {
            from {
                opacity: 0;
                transform: translateY(22px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /*  CARDS  */
        .card {
            background: var(--card);
            border-radius: var(--radius);
            padding: 30px 32px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            transition: var(--transition);
        }
        .card:hover {
            box-shadow: var(--shadow-lg);
        }
        .card h2 {
            font-size: 1.5rem;
            margin-bottom: 6px;
            color: var(--primary);
            font-weight: 700;
            letter-spacing: -0.3px;
        }
        .card .subtitle {
            color: var(--text-light);
            font-size: 0.9rem;
            margin-bottom: 22px;
        }

        /*  FORM ELEMENTS  */
        .form-group {
            margin-bottom: 18px;
        }
        .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--text);
            font-size: 0.9rem;
            letter-spacing: 0.1px;
        }
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 1rem;
            transition: var(--transition);
            background: #fafbfc;
            color: var(--text);
            font-family: inherit;
        }
        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--primary-light);
            box-shadow: 0 0 0 4px rgba(30, 80, 128, 0.08);
            background: #fff;
        }
        .form-row {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }
        .form-row .form-group {
            flex: 1;
            min-width: 180px;
        }
        .btn {
            padding: 12px 28px;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.2px;
            transition: var(--transition);
            text-align: center;
            display: inline-block;
            font-family: inherit;
        }
        .btn-primary {
            background: var(--primary-light);
            color: #fff;
            box-shadow: 0 4px 14px rgba(30, 80, 128, 0.3);
        }
        .btn-primary:hover {
            background: #1a4d78;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(30, 80, 128, 0.4);
        }
        .btn-accent {
            background: var(--accent);
            color: #fff;
            box-shadow: 0 4px 14px rgba(232, 93, 44, 0.3);
        }
        .btn-accent:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(232, 93, 44, 0.4);
        }
        .btn-outline {
            background: #fff;
            color: var(--primary);
            border: 2px solid var(--primary-light);
        }
        .btn-outline:hover {
            background: #f0f5fa;
            transform: translateY(-2px);
        }
        .btn-block {
            width: 100%;
            display: block;
        }
        .btn-lg {
            padding: 15px 36px;
            font-size: 1.05rem;
            border-radius: 30px;
        }
        .btn:disabled {
            opacity: 0.55;
            cursor: not-allowed;
            pointer-events: none;
        }

        /*  DASHBOARD HERO  */
        .hero {
            background: linear-gradient(135deg, #1a3a5c 0%, #1e5080 40%, #1a3a5c 100%);
            border-radius: var(--radius);
            padding: 40px 36px;
            color: #fff;
            text-align: center;
            margin-bottom: 28px;
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }
        .hero::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        .hero h1 {
            font-size: 2.4rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            position: relative;
            z-index: 1;
        }
        .hero p {
            font-size: 1.1rem;
            opacity: 0.9;
            margin-top: 6px;
            position: relative;
            z-index: 1;
        }
        .hero .train-icon {
            font-size: 4rem;
            display: block;
            margin-bottom: 8px;
            position: relative;
            z-index: 1;
        }

        /* Search card on dashboard */
        .search-card {
            margin-top: -10px;
            position: relative;
            z-index: 2;
        }
        .search-card .form-row {
            align-items: flex-end;
        }
        .search-card .btn {
            height: 48px;
            white-space: nowrap;
        }

        /*  TRAIN RESULTS  */
        .train-card {
            background: #fff;
            border-radius: var(--radius);
            padding: 20px 24px;
            margin-bottom: 16px;
            border: 2px solid var(--border);
            transition: var(--transition);
            cursor: default;
            box-shadow: var(--shadow);
        }
        .train-card:hover {
            border-color: var(--primary-light);
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }
        .train-card .train-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }
        .train-card .train-name {
            font-weight: 700;
            font-size: 1.15rem;
            color: var(--primary);
        }
        .train-card .train-number {
            font-size: 0.85rem;
            color: var(--text-light);
            background: #eef3f8;
            padding: 3px 10px;
            border-radius: 12px;
            font-weight: 600;
        }
        .train-card .train-route {
            display: flex;
            align-items: center;
            gap: 14px;
            margin: 14px 0;
            flex-wrap: wrap;
        }
        .train-card .station {
            text-align: center;
        }
        .train-card .station .time {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--text);
        }
        .train-card .station .name {
            font-size: 0.85rem;
            color: var(--text-light);
        }
        .train-card .route-line {
            flex: 1;
            height: 3px;
            background: linear-gradient(90deg, var(--primary-light), var(--accent));
            border-radius: 2px;
            min-width: 60px;
            position: relative;
        }
        .train-card .route-line::after {
            content: '🚆';
            position: absolute;
            top: -14px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 1.2rem;
        }
        .train-card .duration {
            font-size: 0.85rem;
            color: var(--accent);
            font-weight: 600;
            text-align: center;
        }
        .train-card .btn {
            margin-top: 6px;
        }

        /*  SEAT SELECTION  */
        .class-option {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 18px;
            border: 2px solid var(--border);
            border-radius: var(--radius-sm);
            margin-bottom: 12px;
            cursor: pointer;
            transition: var(--transition);
            background: #fafcfd;
            flex-wrap: wrap;
            gap: 10px;
        }
        .class-option:hover {
            border-color: var(--primary-light);
            background: #f6f9fc;
        }
        .class-option.selected {
            border-color: var(--accent);
            background: #fff8f5;
            box-shadow: 0 0 0 5px rgba(232, 93, 44, 0.06);
        }
        .class-option .class-name {
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--text);
        }
        .class-option .class-price {
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--accent);
        }
        .class-option .class-desc {
            font-size: 0.8rem;
            color: var(--text-light);
        }
        .class-radio {
            width: 22px;
            height: 22px;
            accent-color: var(--accent);
            cursor: pointer;
        }
        .seat-counter {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 10px;
        }
        .seat-counter button {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--primary-light);
            background: #fff;
            font-size: 1.3rem;
            cursor: pointer;
            font-weight: 700;
            color: var(--primary);
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .seat-counter button:hover {
            background: var(--primary-light);
            color: #fff;
        }
        .seat-counter span {
            font-size: 1.4rem;
            font-weight: 700;
            min-width: 36px;
            text-align: center;
            color: var(--text);
        }

        /*  TICKET  */
        .ticket {
            background: #fff;
            border: 3px dashed var(--primary-light);
            border-radius: var(--radius);
            padding: 28px;
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }
        .ticket::before,
        .ticket::after {
            content: '';
            position: absolute;
            width: 40px;
            height: 40px;
            background: var(--bg);
            border-radius: 50%;
            top: 50%;
            transform: translateY(-50%);
            border: 3px solid var(--primary-light);
        }
        .ticket::before {
            left: -22px;
        }
        .ticket::after {
            right: -22px;
        }
        .ticket .ticket-header {
            text-align: center;
            border-bottom: 2px solid #eee;
            padding-bottom: 16px;
            margin-bottom: 16px;
        }
        .ticket .ticket-header h3 {
            color: var(--primary);
            font-size: 1.3rem;
        }
        .ticket .ticket-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .ticket .ticket-details .item {
            font-size: 0.95rem;
        }
        .ticket .ticket-details .item strong {
            color: var(--primary);
        }
        .ticket .total-cost {
            text-align: center;
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--accent);
            margin-top: 16px;
            padding-top: 12px;
            border-top: 2px solid #eee;
        }

        /*  MESSAGE  */
        .alert {
            padding: 14px 20px;
            border-radius: var(--radius-sm);
            margin: 14px 0;
            font-weight: 600;
            font-size: 0.95rem;
            animation: fadeSlideIn 0.3s ease;
        }
        .alert-success {
            background: #e8f8f0;
            color: #1a6b3c;
            border: 1px solid #b7e4cf;
        }
        .alert-error {
            background: #fdecea;
            color: #a82020;
            border: 1px solid #f5c6cb;
        }
        .alert-info {
            background: #e8f0fa;
            color: #1a4a7a;
            border: 1px solid #c4d8f0;
        }

        /*  MODAL OVERLAY  */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.55);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.25s ease;
        }
        .modal {
            background: #fff;
            border-radius: var(--radius);
            padding: 32px;
            max-width: 500px;
            width: 90%;
            text-align: center;
            box-shadow: var(--shadow-lg);
            animation: scaleIn 0.3s ease;
        }
        .modal h3 {
            font-size: 1.4rem;
            margin-bottom: 10px;
            color: var(--primary);
        }
        .modal .modal-buttons {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }
        @keyframes scaleIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /*  RESPONSIVE UI */
        @media (max-width: 768px) {
            .navbar {
                padding: 0 14px;
                height: auto;
                padding-top: 10px;
                padding-bottom: 10px;
            }
            .navbar .logo {
                font-size: 1.1rem;
            }
            .nav-links {
                gap: 8px;
            }
            .nav-links button {
                padding: 7px 12px;
                font-size: 0.78rem;
            }
            .hero {
                padding: 28px 18px;
            }
            .hero h1 {
                font-size: 1.5rem;
            }
            .card {
                padding: 20px 16px;
            }
            .train-card .train-route {
                flex-direction: column;
                align-items: flex-start;
                gap: 6px;
            }
            .train-card .route-line {
                width: 100%;
                min-width: auto;
                height: 2px;
            }
            .ticket .ticket-details {
                grid-template-columns: 1fr;
            }
            .form-row {
                flex-direction: column;
            }
        }
        @media (max-width: 480px) {
            .nav-links button {
                padding: 5px 8px;
                font-size: 0.7rem;
                border-radius: 18px;
            }
            .btn {
                padding: 10px 18px;
                font-size: 0.85rem;
            }
            .hero h1 {
                font-size: 1.2rem;
            }
        }
    </style>
</head>
<body>

    <!-- Navigation bar  -->

    <nav class="navbar">
        <div class="logo">
            <span class="icon">🚄</span> Rail<span>Way</span>
        </div>
        <div class="nav-links" id="navLinks">
            <button onclick="navigateTo('dashboard')" id="navDashboard">🏠 Dashboard</button>
            <button onclick="navigateTo('signup')" id="navSignup">📝 Sign Up</button>
            <button onclick="navigateTo('login')" id="navLogin">🔑 Login</button>
            <button onclick="handleLogout()" id="navLogout" style="display:none;">🚪 Logout</button>
            <span class="user-badge" id="userBadge" style="display:none;">
                <span class="avatar" id="userAvatar">U</span>
                <span id="userNameDisplay">User</span>
            </span>
        </div>
    </nav>

    <!-- Main wrapper  -->
    <div class="container">

        
        <!--  DASHBOARD PAGE  -->
        <div class="page active" id="page-dashboard">
            <div class="hero">
                <span class="train-icon">🚆</span>
                <h1>Indian Railway Booking</h1>
                <p>Book your journey across India — fast, easy &amp; secure</p>
            </div>
            <div class="card search-card">
                <h2>🔍 Find Your Train</h2>
                <p class="subtitle">Select your origin and destination to see available trains</p>
                <div class="form-row">
                    <div class="form-group">
                        <label for="fromStation">From (Origin)</label>
                        <select id="fromStation">
                            <option value="">-- Select Origin --</option>
                            <option value="Delhi">Delhi (NDLS)</option>
