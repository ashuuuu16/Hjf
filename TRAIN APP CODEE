            multiplier: 11 },
        };

       
        //  LOCAL STORAGE. 
        function saveToStorage() {
            localStorage.setItem('railway_users', JSON.stringify(APP.users));
            localStorage.setItem('railway_bookings', JSON.stringify(APP.bookings));
            localStorage.setItem('railway_currentUser', JSON.stringify(APP.currentUser));
        }

        function loadFromStorage() {
            const users = localStorage.getItem('railway_users');
            const bookings = localStorage.getItem('railway_bookings');
            const currentUser = localStorage.getItem('railway_currentUser');
            if (users) APP.users = JSON.parse(users);
            if (bookings) APP.bookings = JSON.parse(bookings);
            if (currentUser && currentUser !== 'null') APP.currentUser = JSON.parse(currentUser);
        }

        
        //  NAVIGATION PAGE HANDLER.
        function navigateTo(page) {
            // Hide all pages
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            // Show target page
            const target = document.getElementById('page-' + page);
            if (target) target.classList.add('active');
            // Clear messages
            clearAllMessages();
            // Update nav
            updateNavUI();
            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });

            // If navigating to dashboard, reset search-related state display
            if (page === 'dashboard') {
                document.getElementById('dashboardMsg').innerHTML = '';
            }
            if (page === 'results') {
                // If we have a current search, populate results
                if (APP.currentSearch) {
                    displayTrainResults(APP.currentSearch.from, APP.currentSearch.to);
                }
            }
        }

        function clearAllMessages() {
            const msgIds = ['signupMsg', 'loginMsg', 'dashboardMsg', 'resultsMsg', 'bookingMsg'];
            msgIds.forEach(id => {
                const el = document.getElementById(id);
                if (el) el.innerHTML = '';
            });
        }

        function updateNavUI() {
            const navSignup = document.getElementById('navSignup');
            const navLogin = document.getElementById('navLogin');
            const navLogout = document.getElementById('navLogout');
            const userBadge = document.getElementById('userBadge');
            const userNameDisplay = document.getElementById('userNameDisplay');
            const userAvatar = document.getElementById('userAvatar');

            if (APP.currentUser) {
                navSignup.style.display = 'none';
                navLogin.style.display = 'none';
                navLogout.style.display = 'inline-block';
                userBadge.style.display = 'flex';
                userNameDisplay.textContent = APP.currentUser.name.split(' ')[0];
                userAvatar.textContent = APP.currentUser.name.charAt(0).toUpperCase();
            } else {
                navSignup.style.display = 'inline-block';
                navLogin.style.display = 'inline-block';
                navLogout.style.display = 'none';
                userBadge.style.display = 'none';
            }
        }

       
        //  LOGIN  HANDLERS.
        function handleSignup(e) {
            e.preventDefault();
            const name = document.getElementById('signupName').value.trim();
            const email = document.getElementById('signupEmail').value.trim().toLowerCase();
            const password = document.getElementById('signupPassword').value;
            const msgEl = document.getElementById('signupMsg');

            if (!name || !email || !password) {
                msgEl.innerHTML = '<div class="alert alert-error">⚠️ Please fill all fields.</div>';
                return;
            }
            if (password.length < 6) {
                msgEl.innerHTML = '<div class="alert alert-error">⚠️ Password must be at least 6 characters.</div>';
                return;
            }
            // Check if user exists
            if (APP.users.find(u => u.email === email)) {
                msgEl.innerHTML =
                    '<div class="alert alert-error">⚠️ An account with this email already exists. Please login.</div>';
                return;
            }
            const newUser = { name, email, password };
            APP.users.push(newUser);
            APP.currentUser = newUser;
            saveToStorage();
            msgEl.innerHTML = '<div class="alert alert-success">✅ Account created successfully! Redirecting...</div>';
            document.getElementById('signupForm').reset();
            setTimeout(() => navigateTo('dashboard'), 1200);
        }

        function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById('loginEmail').value.trim().toLowerCase();
            const password = document.getElementById('loginPassword').value;
            const msgEl = document.getElementById('loginMsg');

            if (!email || !password) {
                msgEl.innerHTML = '<div class="alert alert-error">⚠️ Please fill all fields.</div>';
                return;
            }
            const user = APP.users.find(u => u.email === email && u.password === password);
            if (!user) {
                msgEl.innerHTML = '<div class="alert alert-error">⚠️ Invalid email or password. Please try again.</div>';
                return;
            }
            APP.currentUser = user;
            saveToStorage();
            msgEl.innerHTML = '<div class="alert alert-success">✅ Login successful! Redirecting...</div>';
            document.getElementById('loginForm').reset();
            setTimeout(() => navigateTo('dashboard'), 1000);
        }

        function handleLogout() {
            APP.currentUser = null;
            APP.currentSearch = null;
            APP.selectedTrain = null;
            APP.selectedClass = null;
            APP.seatCount = 1;
            saveToStorage();
            updateNavUI();
            navigateTo('dashboard');
            document.getElementById('dashboardMsg').innerHTML =
                '<div class="alert alert-info">👋 You have been logged out successfully.</div>';
        }

        //  TRAIN SEARCH 
        function searchTrains() {
            const from = document.getElementById('fromStation').value;
            const to = document.getElementById('toStation').value;
            const msgEl = document.getElementById('dashboardMsg');

            if (!from || !to) {
                msgEl.innerHTML = '<div class="alert alert-error">⚠️ Please select both origin and destination.</div>';
                return;
            }
            if (from === to) {
                msgEl.innerHTML =
                    '<div class="alert alert-error">⚠️ Origin and destination cannot be the same. Please choose different stations.</div>';
                return;
            }
            msgEl.innerHTML = '';
            APP.currentSearch = { from, to };
            navigateTo('results');
            displayTrainResults(from, to);
        }

        function displayTrainResults(from, to) {
            const resultsList = document.getElementById('trainResultsList');
            const resultsRoute = document.getElementById('resultsRoute');
            const msgEl = document.getElementById('resultsMsg');

            resultsRoute.textContent = `Showing trains from ${from} to ${to}`;

            // Filter trains
            const matchingTrains = TRAINS.filter(t => t.from === from && t.to === to);

            if (matchingTrains.length === 0) {
                resultsList.innerHTML = '';
                msgEl.innerHTML =
                    '<div class="alert alert-info">😔 No direct trains found for this route. Please try a different route.</div>';
                return;
            }
            msgEl.innerHTML = '';

            let html = '';
            matchingTrains.forEach(train => {
                html += `
                <div class="train-card">
                    <div class="train-header">
                        <span class="train-name">🚆 ${train.name}</span>
                        <span class="train-number">#${train.number}</span>
                    </div>
                    <div class="train-route">
                        <div class="station">
                            <div class="time">${train.departure}</div>
                            <div class="name">${train.from}</div>
                        </div>
                        <div style="text-align:center;">
                            <div class="route-line" style="width:120px;"></div>
                            <div class="duration">⏱ ${train.duration}</div>
                        </div>
                        <div class="station">
                            <div class="time">${train.arrival}</div>
                            <div class="name">${train.to}</div>
                        </div>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
                        <span style="font-size:0.9rem;color:var(--text-light);">
                            💰 From ₹${train.prices.general} (General) | Up to ₹${train.prices.firstAC} (1st AC)
                        </span>
                        <button class="btn btn-accent" onclick="selectTrain('${train.id}')">🎫 Book Now</button>
                    </div>
                </div>`;
            });
            resultsList.innerHTML = html;
        }

        //  TRAIN SELECTION & BOOKING PAGE.
        function selectTrain(trainId) {
            if (!APP.currentUser) {
                alert('⚠️ Please login or sign up first to book a ticket.');
                navigateTo('login');
                return;
            }
            const train = TRAINS.find(t => t.id === trainId);
            if (!train) return;
            APP.selectedTrain = train;
            APP.selectedClass = null;
            APP.seatCount = 1;
            navigateTo('booking');
            renderBookingPage();
        }

        function renderBookingPage() {
            const train = APP.selectedTrain;
            if (!train) return;
            document.getElementById('bookingTrainInfo').textContent =
                `Train: ${train.name} (#${train.number}) | ${train.from} → ${train.to} | Dep: ${train.departure} | Arr: ${train.arrival} | Duration: ${train.duration}`;

            const container = document.getElementById('classOptionsContainer');
            let html = '';
            const classKeys = ['general', 'sleeper', 'thirdAC', 'secondAC', 'firstAC'];
            classKeys.forEach(key => {
                const info = CLASS_INFO[key];
                const price = train.prices[key];
                const selected = APP.selectedClass === key ? 'selected' : '';
                html += `
                <div class="class-option ${selected}" onclick="selectClass('${key}')">
                    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                        <input type="radio" name="classSelect" class="class-radio" ${selected ? 'checked' : ''} readonly style="pointer-events:none;">
                        <div>
                            <div class="class-name">${info.emoji} ${info.name}</div>
                            <div class="class-desc">${info.desc}</div>
                        </div>
                    </div>
                    <div class="class-price">₹${price} <span style="font-size:0.8rem;color:var(--text-light);">/seat</span></div>
                </div>`;
            });
            container.innerHTML = html;
            document.getElementById('seatCount').textContent = APP.seatCount;
            updateTotalPrice();
            document.getElementById('bookingMsg').innerHTML = '';
        }

        function selectClass(classKey) {
            APP.selectedClass = classKey;
            renderBookingPage();
        }

        function changeSeats(delta) {
            APP.seatCount = Math.max(1, Math.min(10, APP.seatCount + delta));
            document.getElementById('seatCount').textContent = APP.seatCount;
            updateTotalPrice();
        }

        function updateTotalPrice() {
            const train = APP.selectedTrain;
            const cls = APP.selectedClass;
            let total = 0;
            if (train && cls && train.prices[cls]) {
                total = train.prices[cls] * APP.seatCount;
            }
            document.getElementById('totalPriceDisplay').textContent = '₹' + total.toLocaleString('en-IN');
        }

        function proceedToPay() {
            const msgEl = document.getElementById('bookingMsg');
            if (!APP.selectedClass) {
                msgEl.innerHTML = '<div class="alert alert-error">⚠️ Please select a class before proceeding.</div>';
                return;
            }
            if (!APP.currentUser) {
                msgEl.innerHTML = '<div class="alert alert-error">⚠️ Please login to book tickets.</div>';
                return;
            }
            const train = APP.selectedTrain;
            const total = train.prices[APP.selectedClass] * APP.seatCount;
            document.getElementById('modalTotalAmount').textContent = '₹' + total.toLocaleString('en-IN');
            document.getElementById('paymentModal').style.display = 'flex';
            msgEl.innerHTML = '';
        }

        function confirmPayment() {
            document.getElementById('paymentModal').style.display = 'none';
            const train = APP.selectedTrain;
            const cls = APP.selectedClass;
            const seats = APP.seatCount;
            const total = train.prices[cls] * seats;
            const classInfo = CLASS_INFO[cls];

            // Create booking record
            const booking = {
                id: 'BK' + Date.now().toString(36).toUpperCase(),
                trainNumber: train.number,
                trainName: train.name,
                from: train.from,
                to: train.to,
                departure: train.departure,
                arrival: train.arrival,
                duration: train.duration,
                classType: classInfo.name,
                classEmoji: classInfo.emoji,
                seats: seats,
                pricePerSeat: train.prices[cls],
                totalCost: total,
                passengerName: APP.currentUser.name,
                passengerEmail: APP.currentUser.email,
                bookedAt: new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }),
            };
            APP.bookings.push(booking);
            saveToStorage();

            // Render ticket
            renderTicket(booking);
            navigateTo('ticket');

            // Reset selection
            APP.selectedTrain = null;
            APP.selectedClass = null;
            APP.seatCount = 1;
            APP.currentSearch = null;
        }

        function cancelPayment() {
            document.getElementById('paymentModal').style.display = 'none';
            document.getElementById('bookingMsg').innerHTML =
                '<div class="alert alert-info">❌ Ticket not booked. You can select again or go back.</div>';
        }

        function renderTicket(booking) {
            const ticketContent = document.getElementById('ticketContent');
            ticketContent.innerHTML = `
            <div class="ticket-header">
                <h3>🎫 Ticket Booked Successfully!</h3>
                <p style="color:var(--success);font-weight:700;font-size:1.1rem;">✅ Confirmed</p>
                <p style="font-size:0.85rem;color:var(--text-light);">Booking ID: ${booking.id}</p>
            </div>
            <div class="ticket-details">
                <div class="item"><strong>🚆 Train:</strong> ${booking.trainName} (#${booking.trainNumber})</div>
                <div class="item"><strong>📅 Booked On:</strong> ${booking.bookedAt}</div>
                <div class="item"><strong>📍 From:</strong> ${booking.from}</div>
                <div class="item"><strong>🏁 To:</strong> ${booking.to}</div>
                <div class="item"><strong>🕐 Departure:</strong> ${booking.departure}</div>
                <div class="item"><strong>🕗 Arrival:</strong> ${booking.arrival}</div>
                <div class="item"><strong>⏱ Duration:</strong> ${booking.duration}</div>
                <div class="item"><strong>👤 Passenger:</strong> ${booking.passengerName}</div>
                <div class="item"><strong>💺 Class:</strong> ${booking.classEmoji} ${booking.classType}</div>
                <div class="item"><strong>🎟️ Seats:</strong> ${booking.seats}</div>
                <div class="item"><strong>💰 Price/Seat:</strong> ₹${booking.pricePerSeat.toLocaleString('en-IN')}</div>
            </div>
            <div class="total-cost">💵 Total Cost: ₹${booking.totalCost.toLocaleString('en-IN')}</div>
            <p style="text-align:center;margin-top:12px;font-size:0.85rem;color:var(--text-light);">
                🧾 Please carry a valid ID proof during the journey. Happy travels! 🚂
            </p>`;
        }

        //   INITIALIZATION. 
        function init() {
            loadFromStorage();
            updateNavUI();
            // If user was logged in, show dashboard
            if (APP.currentUser) {
                navigateTo('dashboard');
            } else {
                navigateTo('dashboard');
            }
            // Close modal on clicking overlay (outside modal)
            document.getElementById('paymentModal').addEventListener('click', function(e) {
                if (e.target === this) {
                    cancelPayment();
                }
            });
            // Keyboard escape to close modal
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    const modal = document.getElementById('paymentModal');
                    if (modal.style.display === 'flex') {
                        cancelPayment();
                    }
                }
            });
        }

        // Start the app
        init();
        console.log('🚆 RailWay - Indian Railway Booking System Ready!');
        console.log('📋 Sample routes: Delhi→Mumbai, Delhi→Kolkata, Mumbai→Delhi, Bangalore→Delhi, Delhi→Jaipur, etc.');
        console.log('👤 Sign up to book tickets. All data stored in your browser localStorage.');
    </script>
</body>
</html>
