                        </select>
                    </div>
                    <div class="form-group">
                        <label for="toStation">To (Destination)</label>
                        <select id="toStation">
                            <option value="">-- Select Destination --</option>
                            <option value="Mumbai">Mumbai (CST)</option>
                            <option value="Delhi">Delhi (NDLS)</option>
                            <option value="Kolkata">Kolkata (HWH)</option>
                            <option value="Chennai">Chennai (MAS)</option>
                            <option value="Bangalore">Bangalore (SBC)</option>
                            <option value="Hyderabad">Hyderabad (HYB)</option>
                            <option value="Jaipur">Jaipur (JP)</option>
                            <option value="Ahmedabad">Ahmedabad (ADI)</option>
                            <option value="Lucknow">Lucknow (LKO)</option>
                            <option value="Pune">Pune (PUNE)</option>
                            <option value="Bhagalpur">Bhagalpur (BHAGALPUR)</option>
                            <option value="Banka">Banka (BANKA)</option>
                            <option value="Patna">Patna (PATNA)</option>
                            <option value="Jamalpur">Jamalpur (JAMALPUR)</option>
                          
                        </select>
                    </div>
                    <div class="form-group" style="flex:0 0 auto;">
                        <label>&nbsp;</label>
                        <button class="btn btn-accent btn-lg" onclick="searchTrains()" style="height:48px;">🔎 Search Trains</button>
                    </div>
                </div>
                <div id="dashboardMsg"></div>
            </div>
            <!-- Quick Stats -->
            <div style="display:flex;gap:16px;flex-wrap:wrap;margin-top:20px;">
                <div class="card" style="flex:1;min-width:140px;text-align:center;padding:20px;">
                    <div style="font-size:2rem;">🚆</div>
                    <div style="font-weight:700;color:var(--primary);">12,000+</div>
                    <div style="font-size:0.85rem;color:var(--text-light);">Daily Trains</div>
                </div>
                <div class="card" style="flex:1;min-width:140px;text-align:center;padding:20px;">
                    <div style="font-size:2rem;">🛤️</div>
                    <div style="font-weight:700;color:var(--primary);">68,000 km</div>
                    <div style="font-size:0.85rem;color:var(--text-light);">Rail Network</div>
                </div>
                <div class="card" style="flex:1;min-width:140px;text-align:center;padding:20px;">
